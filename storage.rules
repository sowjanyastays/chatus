rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Only authenticated users can read or write encrypted media files.
    // Files must use the .enc extension (all uploads are pre-encrypted client-side).
    // Individual file size capped at 50 MB.
    match /media/{conversationId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && fileName.matches('.*\\.enc');
    }
  }
}
