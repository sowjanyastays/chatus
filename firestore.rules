rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: any authenticated user can read (needed for email search + loading chat partner info)
    // but only the owner can write their own profile.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Conversations: only the two participants can read, update, or delete.
    // create: the creator must include themselves as a participant.
    match /conversations/{convId} {
      allow read, update, delete:
        if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create:
        if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // Messages subcollection: only participants of the parent conversation may access.
      match /messages/{msgId} {
        allow read, write:
          if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }
  }
}
