# Firebase — copy from your Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Cloud Messaging VAPID key
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=

# Cloudinary — copy from your Cloudinary Dashboard
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
